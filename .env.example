BOT_TOKEN=your-bot-token-from-botfather
ADMIN_TELEGRAM_ID=123456789
GROUP_CHAT_ID=-100123456789
# Language for all user-facing bot text: fa (Persian, default) or en (English).
BOT_LANG=fa
SNAPSHOT_HOUR=12
SESSION_WEEKDAY=monday
MAX_ATTENDEES=14
# Attendance poll: posted weekly on SESSION_POLL_WEEKDAY at SESSION_POLL_HOUR in
# SESSION_POLL_TZ. QUORUM_THRESHOLD is the yes-count at or above which the bot
# announces the session is on and posts payment; MAX_ATTENDEES caps it.
SESSION_POLL_WEEKDAY=thursday
SESSION_POLL_HOUR=20
SESSION_POLL_TZ=America/Los_Angeles
QUORUM_THRESHOLD=10
# Payment block (interpolated into the quorum announcement):
PAYMENT_EMAIL=you@example.com
PAYMENT_AMOUNT=7.5
ACCOUNTING_SHEET_URL=https://docs.google.com/spreadsheets/d/your-sheet-id/edit
WEIGHT_ATTACK=0.4
WEIGHT_DEFENSE=0.4
WEIGHT_SETTING=0.2
CALIBRATION_THRESHOLD=15
QUEUE_DEPTH=5
DATABASE_PATH=data/toop.db
# Don't-know alert thresholds (daily admin DM suggesting /pause_voting):
DK_ALERT_MIN_PROMPTS=10
DK_ALERT_RATE=0.5
DEFAULT_PAUSE_DAYS=14
VPS_SSH=user@your-vps-ip
